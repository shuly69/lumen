# Copy to .env and fill in your key. All vars are prefixed with LUMEN_.
LUMEN_ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional overrides (defaults shown):
# LUMEN_MODEL=claude-haiku-4-5-20251001
# LUMEN_MAX_TOKENS=1024
# LUMEN_TOP_K=4
# LUMEN_CHUNK_SIZE=900
# LUMEN_CHUNK_OVERLAP=150

# Retrieval strategy: bm25 (default, offline) | semantic | hybrid
# semantic/hybrid need the extra:  pip install ".[semantic]"
# LUMEN_RETRIEVER=hybrid
# LUMEN_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
